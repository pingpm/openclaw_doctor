{
  "version": 2,
  "rewrites": [
    { "source": "/zh", "destination": "/website/index.zh.html" },
    { "source": "/", "destination": "/website/index.html" }
  ],
  "headers": [
    {
      "source": "/install.sh",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/server.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript; charset=utf-8" }]
    }
  ]
}
